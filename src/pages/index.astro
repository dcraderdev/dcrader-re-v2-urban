<style>
  /* Ticker animation */
  @keyframes marquee {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-50%); }
  }

  .animate-marquee {
    animation: marquee 28s linear infinite;
  }

  .animate-marquee:hover {
    animation-play-state: paused;
  }

  /* Nav scroll state */
  #masthead.scrolled {
    border-bottom-color: rgba(255, 255, 255, 0.12) !important;
  }

  /* Floating button visible state */
  #float-cta.visible {
    opacity: 1;
    pointer-events: auto;
  }

  /* Form input focus styles */
  input:focus,
  textarea:focus,
  select:focus {
    outline: none;
    box-shadow: inset 0 0 0 1px #0047FF;
  }

  /* Ensure no border-radius anywhere */
  * {
    border-radius: 0 !important;
  }

  /* Select arrow color */
  select option {
    background-color: #0C0C0C;
    color: #F5F5F5;
  }
</style>

<script>
  // Populate nav date
  const dateEl = document.getElementById('nav-date');
  if (dateEl) {
    const d = new Date();
    dateEl.textContent = d.toLocaleDateString('en-US', {
      weekday: 'long',
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    }).toUpperCase();
  }

  // Scroll effects: masthead border + floating CTA
  const masthead = document.getElementById('masthead');
  const floatCta = document.getElementById('float-cta');

  function onScroll() {
    const scrolled = window.scrollY > 60;
    if (masthead) {
      if (scrolled) {
        masthead.classList.add('scrolled');
      } else {
        masthead.classList.remove('scrolled');
      }
    }
    if (floatCta) {
      if (window.scrollY > 400) {
        floatCta.classList.add('visible');
      } else {
        floatCta.classList.remove('visible');
      }
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
