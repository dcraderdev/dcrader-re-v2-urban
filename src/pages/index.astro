---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const listings = [
  {
    address: '245 W 74th St',
    neighborhood: 'UPPER WEST SIDE',
    headline: 'WEST SIDE RESIDENCE',
    beds: '3BR',
    sqft: '2,240 SF',
    price: '$5,200,000',
    img: 'https://images.unsplash.com/photo-1560184897-ae75f418493e?w=600&q=85',
  },
  {
    address: '480 Park Ave',
    neighborhood: 'MIDTOWN EAST',
    headline: 'PARK AVENUE TOWER',
    beds: '4BR',
    sqft: '3,180 SF',
    price: '$8,900,000',
    img: 'https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?w=600&q=85',
  },
  {
    address: '1 Central Park West',
    neighborhood: 'UPPER WEST SIDE',
    headline: 'PARK VIEW FLAT',
    beds: '2BR',
    sqft: '1,620 SF',
    price: '$3,800,000',
    img: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600&q=85',
  },
  {
    address: '56 Leonard St',
    neighborhood: 'TRIBECA',
    headline: 'TRIBECA PENTHOUSE',
    beds: 'PH',
    sqft: '4,900 SF',
    price: '$15,500,000',
    img: 'https://images.unsplash.com/photo-1570129477492-45c003edd2be?w=600&q=85',
  },
];

const tickerText = '520 UNITS SOLD · 14 YEARS IN MARKET · $2.1B VOLUME · 89 OFF-MARKET DEALS · 12 DAYS AVG ON MARKET · 98% LIST-TO-SELL RATIO · ';
---

<Layout>

  <!-- ================================================================
       NAV — STICKY, TWO-ROW NEWSPAPER MASTHEAD
       ================================================================ -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-black">
    <!-- Top meta row -->
    <div class="flex items-center justify-between px-6 py-2 border-b border-white/10">
      <span class="font-mono text-[10px] text-white/40 uppercase tracking-widest">New York City</span>
      <span class="font-mono text-[10px] text-white uppercase tracking-widest font-bold">MARCUS CHEN REAL ESTATE</span>
      <span class="font-mono text-[10px] text-white/40 uppercase tracking-widest">Est. 2011</span>
    </div>
    <!-- Bottom nav row -->
    <nav class="flex items-center justify-center gap-8 px-6 py-3 border-b border-white/10">
      {[
        ['LISTINGS', '#listings'],
        ['NEIGHBORHOODS', '#listings'],
        ['ABOUT', '#about'],
        ['SOLD', '#numbers'],
        ['CONTACT', '#contact'],
      ].map(([label, href]) => (
        <a
          href={href}
          class="font-mono text-[11px] text-white/60 uppercase tracking-widest hover:text-white transition-colors duration-150"
        >
          {label}
        </a>
      ))}
    </nav>
  </header>

  <!-- ================================================================
       HERO — 4-COLUMN NEWSPAPER GRID (2-col text | 2-col image)
       ================================================================ -->
  <section class="min-h-screen grid grid-cols-1 md:grid-cols-2 bg-black" style="padding-top: 89px;">
    <!-- Left columns: text -->
    <div class="flex flex-col justify-center px-8 md:px-12 lg:px-16 py-16 border-r border-white/10">
      <!-- Masthead label -->
      <p class="font-mono text-[10px] text-white/40 uppercase tracking-widest mb-4">
        EXCLUSIVE MANHATTAN RESIDENCES
      </p>
      <!-- Cobalt rule -->
      <div class="h-[2px] bg-cobalt mb-8" style="width: 60px;"></div>

      <!-- H1 stacked -->
      <h1 class="font-sans text-white leading-none mb-6" style="font-size: clamp(3.5rem, 9vw, 7.5rem); font-weight: 900; letter-spacing: -0.04em; line-height: 0.92;">
        MARCUS<br />CHEN
      </h1>

      <p class="font-sans text-white/50 text-base mb-10" style="font-weight: 400;">
        NYC's most connected broker
      </p>

      <!-- Two stat boxes -->
      <div class="flex gap-0 mb-10">
        <div class="border border-white/15 px-6 py-4 flex-1">
          <p class="font-mono text-3xl text-white font-bold" style="letter-spacing: -0.02em;">520</p>
          <p class="font-mono text-[10px] text-white/40 uppercase tracking-widest mt-1">UNITS SOLD</p>
        </div>
        <div class="border border-white/15 border-l-0 px-6 py-4 flex-1">
          <p class="font-mono text-3xl text-white font-bold" style="letter-spacing: -0.02em;">14yr</p>
          <p class="font-mono text-[10px] text-white/40 uppercase tracking-widest mt-1">IN MARKET</p>
        </div>
      </div>

      <!-- Cobalt CTA -->
      <div>
        <a
          href="#listings"
          class="inline-block bg-cobalt hover:bg-cobalt-dark text-white font-mono text-[11px] uppercase tracking-widest px-8 py-4 transition-colors duration-150"
          style="letter-spacing: 0.15em;"
        >
          VIEW LISTINGS
        </a>
      </div>
    </div>

    <!-- Right columns: photo -->
    <div class="relative min-h-[55vh] md:min-h-full overflow-hidden">
      <img
        src="https://images.unsplash.com/photo-1486325212027-8081e485255e?w=1200&q=90&fit=crop"
        alt="Manhattan"
        class="absolute inset-0 w-full h-full object-cover"
        style="filter: grayscale(100%);"
        loading="eager"
      />
    </div>
  </section>

  <!-- ================================================================
       STAT TICKER — SCROLLING BLACK BAR
       ================================================================ -->
  <div class="bg-black border-t border-b border-white/10 overflow-hidden py-4" aria-hidden="true">
    <div class="flex whitespace-nowrap" style="animation: ticker 30s linear infinite; display: flex; width: max-content;">
      <span class="font-mono text-[11px] text-white uppercase tracking-widest px-4">{tickerText}</span>
      <span class="font-mono text-[11px] text-white uppercase tracking-widest px-4">{tickerText}</span>
    </div>
  </div>

  <!-- ================================================================
       LISTINGS — 4-COLUMN NEWSPAPER CLASSIFIED
       ================================================================ -->
  <section id="listings" class="bg-white py-16 px-6 md:px-12 lg:px-16">
    <!-- Section masthead header -->
    <div class="mb-10 max-w-screen-xl mx-auto">
      <div class="h-[3px] bg-black mb-3"></div>
      <h2 class="font-mono text-[11px] text-black/40 uppercase tracking-widest mb-0">
        CURRENT OFFERINGS
      </h2>
      <div class="h-px bg-black/10 mt-3"></div>
    </div>

    <!-- 4-column editorial listings grid -->
    <div class="max-w-screen-xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-0">
      {listings.map((listing, i) => (
        <article
          class="p-6"
          style={{
            borderTop: '1px solid rgba(0,0,0,0.1)',
            borderLeft: i > 0 ? '1px solid rgba(0,0,0,0.1)' : 'none',
          }}
        >
          <!-- B&W photo -->
          <div class="mb-4 overflow-hidden" style="aspect-ratio: 3/2;">
            <img
              src={listing.img}
              alt={listing.headline}
              class="w-full h-full object-cover"
              style="filter: grayscale(100%) contrast(1.1);"
              loading="lazy"
            />
          </div>

          <!-- Neighborhood label -->
          <p class="font-mono text-[9px] text-black/40 uppercase tracking-widest mb-2">
            {listing.neighborhood}
          </p>

          <!-- Editorial headline -->
          <h3 class="font-sans text-black mb-1" style="font-weight: 900; font-size: 1.1rem; letter-spacing: -0.02em; line-height: 1.1;">
            {listing.headline}
          </h3>

          <!-- Address -->
          <p class="font-mono text-[10px] text-black/40 mb-3">{listing.address}</p>

          <!-- Price bold -->
          <p class="font-sans text-black mb-2" style="font-weight: 900; font-size: 1.3rem; letter-spacing: -0.03em;">
            {listing.price}
          </p>

          <!-- Details mono -->
          <p class="font-mono text-[10px] text-black/50 uppercase tracking-wider mb-4">
            {listing.beds} / {listing.sqft}
          </p>

          <!-- Cobalt enquire link -->
          <a
            href="#contact"
            class="font-mono text-[10px] text-cobalt uppercase tracking-widest hover:underline"
          >
            ENQUIRE →
          </a>
        </article>
      ))}
    </div>
  </section>

  <!-- ================================================================
       ABOUT — MAGAZINE PROFILE / INTERVIEW FORMAT
       ================================================================ -->
  <section id="about" class="bg-ink-mid py-16 px-6 md:px-12 lg:px-16">
    <div class="max-w-screen-xl mx-auto">
      <!-- Section label -->
      <div class="mb-10">
        <div class="h-[2px] bg-white/10 mb-3"></div>
        <p class="font-mono text-[11px] text-white/30 uppercase tracking-widest">PROFILE</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-0 md:gap-16">
        <!-- Left: large pull quote -->
        <div class="flex flex-col justify-center border-r border-white/10 pr-0 md:pr-16 mb-12 md:mb-0">
          <!-- Giant opening mark -->
          <p class="font-sans text-cobalt leading-none mb-4 select-none" style="font-size: 8rem; font-weight: 900; line-height: 1; opacity: 0.3;">"</p>
          <blockquote>
            <p class="font-sans text-white leading-snug mb-6" style="font-weight: 900; font-size: clamp(1.4rem, 3vw, 2.2rem); letter-spacing: -0.03em;">
              I've sold in every market since 2008.
            </p>
          </blockquote>
          <p class="font-mono text-[10px] text-white/30 uppercase tracking-widest">
            — Marcus Chen, Compass NYC
          </p>

          <!-- Additional pull stats -->
          <div class="mt-12 space-y-4">
            <div class="border-t border-white/10 pt-4">
              <p class="font-mono text-[10px] text-white/30 uppercase tracking-widest mb-1">Office</p>
              <p class="font-sans text-white/70 text-sm">730 Fifth Avenue, New York, NY</p>
            </div>
            <div class="border-t border-white/10 pt-4">
              <p class="font-mono text-[10px] text-white/30 uppercase tracking-widest mb-1">Brokerage</p>
              <p class="font-sans text-white/70 text-sm">Compass · Private Client</p>
            </div>
          </div>
        </div>

        <!-- Right: bio paragraphs -->
        <div class="flex flex-col justify-center">
          <h2 class="font-sans text-white mb-2 leading-none" style="font-weight: 900; font-size: clamp(2.5rem, 5vw, 4rem); letter-spacing: -0.04em;">
            MARCUS<br />CHEN
          </h2>
          <p class="font-mono text-[10px] text-white/30 uppercase tracking-widest mb-8">
            Licensed Associate Broker · Compass · New York
          </p>

          <p class="font-sans text-white/60 leading-relaxed text-sm mb-5">
            Marcus Chen has sold 520+ units across Manhattan's most coveted addresses — from the pre-war
            co-ops of the Upper West Side to the glass towers of Hudson Yards. A former Goldman Sachs
            analyst who walked away from finance to study how cities work at street level, Marcus built
            his practice entirely on trust and access.
          </p>
          <p class="font-sans text-white/60 leading-relaxed text-sm mb-5">
            He joined Compass as a Private Client broker in 2016, consistently ranking in the top 1%
            of NYC agents. His clients include finance executives, media figures, and institutional
            investors who require absolute discretion and off-market reach.
          </p>
          <p class="font-sans text-white/60 leading-relaxed text-sm">
            Marcus has operated through every market cycle since 2008. He doesn't advertise. He doesn't
            pitch. He executes — and his 98% list-to-sell ratio reflects exactly that.
          </p>

          <!-- Credentials list -->
          <div class="mt-8 border-t border-white/10 pt-6">
            <p class="font-mono text-[10px] text-white/30 uppercase tracking-widest mb-4">Credentials</p>
            <ul class="space-y-2">
              {[
                'B.A. Urban Studies, Columbia University, 2008',
                'Licensed Associate Real Estate Broker, NYS',
                'Certified Luxury Home Marketing Specialist',
                'Member, Real Estate Board of New York (REBNY)',
                'Top 1% Compass Agent, NYC Region — 2019–2024',
              ].map((item) => (
                <li class="font-mono text-[10px] text-white/40 flex items-start gap-3">
                  <span class="text-cobalt select-none">—</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================================
       BY THE NUMBERS — 4-CELL GRID
       ================================================================ -->
  <section id="numbers" class="bg-silver py-16 px-6 md:px-12 lg:px-16">
    <div class="max-w-screen-xl mx-auto">
      <!-- Section masthead -->
      <div class="mb-10">
        <div class="h-[3px] bg-black mb-3"></div>
        <h2 class="font-mono text-[11px] text-black/40 uppercase tracking-widest">BY THE NUMBERS</h2>
        <div class="h-px bg-black/10 mt-3"></div>
      </div>

      <!-- 4-cell grid -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-0">
        {[
          { stat: '520+', label: 'UNITS SOLD' },
          { stat: '$2.1B', label: 'TOTAL VOLUME' },
          { stat: '14', label: 'YEARS IN MARKET' },
          { stat: '89', label: 'OFF-MARKET DEALS' },
        ].map((item, i) => (
          <div
            class="px-8 py-10"
            style={{
              borderTop: '1px solid rgba(0,0,0,0.12)',
              borderLeft: i > 0 ? '1px solid rgba(0,0,0,0.12)' : 'none',
            }}
          >
            <p class="font-sans text-black leading-none mb-3" style="font-weight: 900; font-size: clamp(2.5rem, 5vw, 4rem); letter-spacing: -0.04em;">
              {item.stat}
            </p>
            <p class="font-mono text-[10px] text-black/40 uppercase tracking-widest">{item.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ================================================================
       TESTIMONIALS — NEWSPAPER PULL QUOTE FORMAT
       ================================================================ -->
  <section id="testimonials" class="bg-white py-16 px-6 md:px-12 lg:px-16">
    <div class="max-w-screen-xl mx-auto">
      <!-- Section masthead -->
      <div class="mb-10">
        <div class="h-[3px] bg-black mb-3"></div>
        <h2 class="font-mono text-[11px] text-black/40 uppercase tracking-widest">CLIENT RECORD</h2>
        <div class="h-px bg-black/10 mt-3"></div>
      </div>

      <!-- 2-column testimonials -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
        <!-- Testimonial 1 -->
        <div class="p-10 border border-black/10">
          <p class="font-sans text-cobalt leading-none mb-6 select-none" style="font-size: 5rem; font-weight: 900; line-height: 1; opacity: 0.2;">"</p>
          <blockquote>
            <p class="font-sans text-black leading-relaxed mb-6" style="font-size: 1.05rem; font-weight: 400;">
              He sold our apartment in 48 hours at 8% over ask. In this market.
            </p>
            <footer class="font-mono text-[10px] text-black/40 uppercase tracking-widest">
              — Robert K., UWS
            </footer>
          </blockquote>
        </div>

        <!-- Testimonial 2 -->
        <div class="p-10 border border-black/10 border-l-0">
          <p class="font-sans text-cobalt leading-none mb-6 select-none" style="font-size: 5rem; font-weight: 900; line-height: 1; opacity: 0.2;">"</p>
          <blockquote>
            <p class="font-sans text-black leading-relaxed mb-6" style="font-size: 1.05rem; font-weight: 400;">
              Marcus has access to properties before they're even photographed. Worth every basis point.
            </p>
            <footer class="font-mono text-[10px] text-black/40 uppercase tracking-widest">
              — Ananya M., Park Slope
            </footer>
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================================
       CONTACT / VALUATION — FULL BLACK SECTION
       ================================================================ -->
  <section id="contact" class="bg-black py-16 px-6 md:px-12 lg:px-16">
    <div class="max-w-screen-xl mx-auto">
      <!-- Section label -->
      <div class="mb-10">
        <div class="h-[2px] bg-white/10 mb-3"></div>
        <h2 class="font-sans text-white leading-none mb-1" style="font-weight: 900; font-size: clamp(2.5rem, 6vw, 5rem); letter-spacing: -0.04em;">
          CONTACT
        </h2>
        <p class="font-mono text-[10px] text-white/30 uppercase tracking-widest">
          Or call: (212) 555-0847
        </p>
      </div>

      <!-- Form -->
      <form
        onsubmit="event.preventDefault(); alert('Thank you. Marcus will be in touch within 24 hours.');"
        class="max-w-2xl"
      >
        <!-- Name -->
        <div class="mb-0 border border-white/15">
          <label class="block font-mono text-[10px] text-white/30 uppercase tracking-widest px-5 pt-4 pb-1">
            NAME
          </label>
          <input
            type="text"
            name="name"
            placeholder="Full Name"
            required
            class="w-full bg-transparent text-white font-sans text-base px-5 pb-4 focus:outline-none placeholder:text-white/15"
          />
        </div>

        <!-- Email -->
        <div class="mb-0 border border-white/15 border-t-0">
          <label class="block font-mono text-[10px] text-white/30 uppercase tracking-widest px-5 pt-4 pb-1">
            EMAIL
          </label>
          <input
            type="email"
            name="email"
            placeholder="your@email.com"
            required
            class="w-full bg-transparent text-white font-sans text-base px-5 pb-4 focus:outline-none placeholder:text-white/15"
          />
        </div>

        <!-- Property -->
        <div class="mb-0 border border-white/15 border-t-0">
          <label class="block font-mono text-[10px] text-white/30 uppercase tracking-widest px-5 pt-4 pb-1">
            PROPERTY / INTEREST
          </label>
          <input
            type="text"
            name="property"
            placeholder="e.g. Tribeca loft, 2BR, $3M budget"
            class="w-full bg-transparent text-white font-sans text-base px-5 pb-4 focus:outline-none placeholder:text-white/15"
          />
        </div>

        <!-- Message -->
        <div class="mb-0 border border-white/15 border-t-0">
          <label class="block font-mono text-[10px] text-white/30 uppercase tracking-widest px-5 pt-4 pb-1">
            MESSAGE
          </label>
          <textarea
            name="message"
            rows="5"
            placeholder="Tell Marcus about your needs..."
            class="w-full bg-transparent text-white font-sans text-base px-5 pb-4 focus:outline-none placeholder:text-white/15 resize-none"
          ></textarea>
        </div>

        <!-- Cobalt SEND button -->
        <button
          type="submit"
          class="w-full bg-cobalt hover:bg-cobalt-dark text-white font-mono text-[11px] uppercase tracking-widest py-5 transition-colors duration-150"
          style="letter-spacing: 0.15em;"
        >
          SEND
        </button>
      </form>
    </div>
  </section>

  <!-- ================================================================
       FOOTER — NEWSPAPER STYLE
       ================================================================ -->
  <footer class="bg-black border-t border-white/10 py-10 px-6 md:px-12 lg:px-16">
    <div class="max-w-screen-xl mx-auto">
      <div class="h-[2px] bg-white/10 mb-6"></div>
      <p class="font-mono text-[10px] text-white/40 uppercase tracking-widest text-center mb-3">
        MARCUS CHEN REAL ESTATE · COMPASS · 730 FIFTH AVENUE, NEW YORK, NY 10019 · (212) 555-0847
      </p>
      <div class="h-px bg-white/10 mb-4"></div>
      <p class="font-mono text-[9px] text-white/20 uppercase tracking-widest text-center">
        NYS Licensed Associate Broker · License #10491234567 · Equal Housing Opportunity · © 2025 Marcus Chen Real Estate
      </p>
    </div>
  </footer>

</Layout>

<style>
  /* Ticker animation */
  @keyframes ticker {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Ensure hard edges everywhere */
  * {
    border-radius: 0 !important;
  }

  /* White input on black background */
  input:focus,
  textarea:focus {
    outline: none;
    box-shadow: inset 0 0 0 1px #0047FF;
  }
</style>
